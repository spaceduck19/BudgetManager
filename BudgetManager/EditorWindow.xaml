<Window x:Class="BudgetManager.EditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BudgetManager"
        mc:Ignorable="d"
        xmlns:models="clr-namespace:BudgetManager.Models"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        
        Title="Tranzakció Szerkesztése" Height="370" Width="300" WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <ObjectDataProvider x:Key="TransactionTypeEnum" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="models:TransactionType"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </Window.Resources>

    <StackPanel Margin="20">
        <TextBlock Text="Cím:" />
        <TextBox Text="{Binding Title}" Margin="0,0,0,10" />

        <TextBlock Text="Összeg (Ft):" />
        <TextBox Text="{Binding Amount}" Margin="0,0,0,10" />

        <TextBlock Text="Típus (Bevétel/Kiadás):" />
        <ComboBox ItemsSource="{Binding Source={StaticResource TransactionTypeEnum}}" 
                  SelectedItem="{Binding Type}" 
                  Margin="0,0,0,10" />

        <TextBlock Text="Kategória:" />
        <ComboBox Text="{Binding Category}" IsEditable="True" Margin="0,0,0,20">
            <ComboBoxItem Content="Fizetés" />
            <ComboBoxItem Content="Étel" />
            <ComboBoxItem Content="Utazás" />
            <ComboBoxItem Content="Szórakozás" />
            <ComboBoxItem Content="Általános" />
        </ComboBox>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="Mentés" Click="Save_Click" Width="80" Margin="10" IsDefault="True"/>
            <Button Content="Mégse" Click="Cancel_Click" Width="80" Margin="10" IsCancel="True"/>
        </StackPanel>
    </StackPanel>
</Window>